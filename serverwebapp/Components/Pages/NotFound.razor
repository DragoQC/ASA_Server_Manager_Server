@page "/not-found"
@layout GlobalPage

<PageTitle>Not Found</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-cyan-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 text-center shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="flex flex-wrap items-center justify-center gap-4">
        <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">404</p>
    </div>

    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white md:text-5xl">Page not found.</h1>

    <p class="mt-4 text-base leading-7 text-neutral-300 md:text-lg">This route is outside the ASA manager UI.</p>

    <div class="mt-6">
        <a href="/" class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-cyan-400/25">
            Back to server page
        </a>
    </div>
</section>
