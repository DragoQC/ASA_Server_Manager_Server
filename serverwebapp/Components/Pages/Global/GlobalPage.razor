@inherits LayoutComponentBase
@implements IDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AsaServerManager.Web.Services.AsaManagerService AsaManagerService

<div
	class="relative grid min-h-screen grid-rows-[auto_minmax(0,1fr)_auto] overflow-hidden bg-transparent text-neutral-100">
	<div class="pointer-events-none absolute inset-0 overflow-hidden">
		<div class="absolute -left-32 -top-40 h-72 w-72 rounded-full bg-cyan-400/20 blur-3xl"></div>
		<div class="absolute -right-24 top-20 h-80 w-80 rounded-full bg-emerald-400/15 blur-3xl"></div>
		<div class="absolute -bottom-40 left-1/3 h-96 w-96 rounded-full bg-sky-400/12 blur-3xl"></div>
	</div>

	<header class="relative z-10 border-b border-black/10 bg-black/30 shadow-[0_10px_28px_rgba(0,0,0,0.1)] backdrop-blur-[2px]">
		<div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-5 lg:px-8">
			<a href="/" class="flex items-center gap-3">
				<span
					class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-cyan-300/30 bg-cyan-400/15 text-sm font-semibold text-cyan-100 shadow-[0_0_20px_rgba(34,211,238,0.35)]">
					ASA
				</span>
				<span>
					<span class="block text-xs uppercase tracking-[0.35em] text-cyan-200/70">Ark Survival Ascended</span>
					<span class="block text-lg font-semibold text-white">Server Manager</span>
				</span>
			</a>

			<div class="flex flex-wrap items-center gap-3">
				<span class="text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-cyan-200/75">
					Server state
				</span>
				<StatusTag Text="@AsaManagerService.CurrentStatus.DisplayText" />
			</div>
		</div>

		<nav class="mx-auto flex max-w-7xl flex-wrap gap-3 px-6 pb-5 lg:px-8">
			@if (_isAuthenticated)
			{
				@foreach (NavigationItem item in NavigationItems)
				{
					<GlobalNavLink Href="@item.Href" Label="@item.Label" Match="@item.Match" />
				}

				<form method="post" action="/auth/logout" class="contents">
					<button type="submit"
									class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.15)] transition hover:bg-cyan-400/15">
						Logout
					</button>
				</form>
			}
			else
			{
				<a href="/admin/login"
				   class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.15)] transition hover:bg-cyan-400/15">
					Admin login
				</a>
			}
		</nav>
	</header>

	<main class="relative z-10 mx-auto flex min-h-0 w-full max-w-7xl flex-col px-6 pb-10 lg:px-8">
		@Body
	</main>

	<footer class="relative z-10 border-t border-white/10 bg-black/20">
		<div
			class="mx-auto flex max-w-7xl flex-col gap-3 px-6 py-5 text-sm text-neutral-400 lg:flex-row lg:items-center lg:justify-between lg:px-8">
			<p>Single-server neon control surface for ASA.</p>
			<p class="flex flex-wrap items-center gap-x-3 gap-y-2 text-cyan-100/70">
				<span>Original panel made by Alex / DragoQC 🐉</span>
				<a href="https://github.com/DragoQC"
				   target="_blank"
				   rel="noopener noreferrer"
				   class="transition hover:text-cyan-100">
					GitHub
				</a>
				<a href="https://github.com/DragoQC/ASA_Server_Manager"
				   target="_blank"
				   rel="noopener noreferrer"
				   class="transition hover:text-cyan-100">
					ASA Server Manager repo
				</a>
			</p>
		</div>
	</footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
	Connection issue or app error.
	<a href="." class="reload">Reload</a>
	<span class="dismiss">Close</span>
</div>

@code {
	private static readonly NavigationItem[] NavigationItems =
	[
			new NavigationItem(Href: "/admin/dashboard", Label: "Dashboard", NavLinkMatch.All),
			new NavigationItem(Href: "/admin/install", Label: "Install"),
			new NavigationItem(Href: "/admin/server-config", Label: "Server Config"),
			new NavigationItem(Href: "/admin/validate", Label: "Validate"),
			new NavigationItem(Href: "/admin/game-config", Label: "Game Config"),
			new NavigationItem(Href: "/admin/logs", Label: "Logs"),
			new NavigationItem(Href: "/admin/game-shell", Label: "Game Shell"),
			new NavigationItem(Href: "/admin/host-shell", Label: "Host Shell"),
			new NavigationItem(Href: "/admin/settings", Label: "Settings"),
			new NavigationItem(Href: "/admin/email", Label: "Email")
	];

	private bool _isAuthenticated;

	protected override async Task OnInitializedAsync()
	{
		AuthenticationState authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		_isAuthenticated = authenticationState.User.Identity?.IsAuthenticated == true;
		AsaManagerService.Changed += HandleAsaServiceStateChanged;
		await AsaManagerService.EnsureStartedAsync();
	}

	private void HandleAsaServiceStateChanged()
	{
		_ = InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		AsaManagerService.Changed -= HandleAsaServiceStateChanged;
	}

	private sealed record NavigationItem(string Href, string Label, NavLinkMatch Match = NavLinkMatch.Prefix);
}
