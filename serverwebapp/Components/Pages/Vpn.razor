@page "/admin/vpn"
@inject AsaServerManager.Web.Services.InstallStateService InstallStateService

<PageTitle>VPN</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-app-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-app-300">VPN</p>
            <StatusTag Text="WireGuard client" />
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Enable VPN connection</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
                This node can be prepared as a WireGuard client for the control machine. Nothing is installed until you confirm the action below.
            </p>
            <p class="mt-3 max-w-3xl text-sm leading-6 text-app-200/80">
                Enabling VPN here installs WireGuard client tools and prepares the node to receive its configuration later from the control side.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="@GetStatusMessageClass()">
                @_statusMessage
            </div>
        }

        <div class="grid gap-6 xl:grid-cols-[minmax(0,1.4fr)_24rem]">
            <section class="rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
                <div class="space-y-4">
                    <div class="flex flex-wrap items-center gap-3">
                        <h2 class="text-3xl font-semibold text-white">Node preparation</h2>
                        <StatusTag Text="Manual confirmation" />
                    </div>

                    <p class="max-w-3xl text-base leading-7 text-neutral-300">
                        Use this once per node when you want to make it ready for the control machine VPN. This does not install a VPN by default and it does not push any peer configuration yet.
                    </p>

                    <div class="rounded-[1.6rem] border border-app-300/20 bg-app-400/10 p-6 shadow-[0_0_24px_rgba(34,211,238,0.12)]">
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-app-300">What this does</p>
                        <div class="mt-4 grid gap-3 md:grid-cols-3">
                            <div class="rounded-[1.2rem] border border-white/10 bg-black/20 p-4">
                                <p class="text-sm font-medium text-white">Install client</p>
                                <p class="mt-2 text-sm leading-6 text-neutral-300">Installs WireGuard client tools on this machine.</p>
                            </div>
                            <div class="rounded-[1.2rem] border border-white/10 bg-black/20 p-4">
                                <p class="text-sm font-medium text-white">Prepare service control</p>
                                <p class="mt-2 text-sm leading-6 text-neutral-300">Allows the panel to start, stop, and enable <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">wg-quick@wg0</code>.</p>
                            </div>
                            <div class="rounded-[1.2rem] border border-white/10 bg-black/20 p-4">
                                <p class="text-sm font-medium text-white">Wait for config</p>
                                <p class="mt-2 text-sm leading-6 text-neutral-300">The actual peer config still comes later from the control machine.</p>
                            </div>
                        </div>

                        <div class="mt-6">
                            <button type="button"
                                    @onclick="OpenEnableDialog"
                                    disabled="@_isEnablingVpn"
                                    class="inline-flex rounded-full border border-app-300/30 bg-app-400/15 px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-app-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-app-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                                @(_isEnablingVpn ? "Enabling VPN..." : "Enable VPN")
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <aside class="space-y-4 rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
                <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-app-300">Current step</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <StatusTag Text="Opt-in" />
                        <StatusTag Text="No config yet" />
                    </div>
                    <p class="mt-4 text-sm leading-6 text-neutral-300">
                        This page only prepares the node. It does not create or apply <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">wg0.conf</code> yet.
                    </p>
                </div>

                <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-app-300">Future service</p>
                    <p class="mt-3 text-sm leading-6 text-neutral-300">
                        The prepared interface name is <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">wg0</code> through <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">wg-quick@wg0</code>.
                    </p>
                </div>

                <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-app-300">Next step later</p>
                    <p class="mt-3 text-sm leading-6 text-neutral-300">
                        Once the control app sends the node config, this server can start and auto-enable the WireGuard client service.
                    </p>
                </div>
            </aside>
        </div>
    </div>
</section>

<ConfirmationDialog IsOpen="@_showEnableDialog"
                    IsBusy="@_isEnablingVpn"
                    Eyebrow="VPN"
                    Title="Do you want to enable VPN connection to this node?"
                    Message="If you continue, this will install WireGuard and prepare the node to receive its configuration from the control machine."
                    ConfirmText="Enable VPN"
                    CancelText="Cancel"
                    OnConfirm="EnableVpnAsync"
                    OnCancel="CloseEnableDialog" />

@code {
    private bool _showEnableDialog;
    private bool _isEnablingVpn;
    private string? _statusMessage;
    private bool _statusIsError;

    private void OpenEnableDialog()
    {
        _showEnableDialog = true;
    }

    private Task CloseEnableDialog()
    {
        if (_isEnablingVpn)
        {
            return Task.CompletedTask;
        }

        _showEnableDialog = false;
        return Task.CompletedTask;
    }

    private Task EnableVpnAsync()
    {
        _showEnableDialog = false;
        _isEnablingVpn = true;
        _statusMessage = "Installing WireGuard client tools and preparing the node...";
        _statusIsError = false;
        _ = EnableVpnInBackgroundAsync();
        return Task.CompletedTask;
    }

    private async Task EnableVpnInBackgroundAsync()
    {
        try
        {
            _statusMessage = await InstallStateService.InstallWireGuardClientAsync();
            _statusIsError = false;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isEnablingVpn = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetStatusMessageClass()
    {
        return _statusIsError
            ? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "rounded-2xl border border-app-300/20 bg-app-400/10 px-5 py-4 text-sm text-app-100";
    }
}
