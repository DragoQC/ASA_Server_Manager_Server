@page "/admin/config"
@page "/admin/game-config"
@inject AsaServerManager.Web.Services.GameConfigService GameConfigService
@inject AsaServerManager.Web.Services.InstallStateService InstallStateService
@inject AsaServerManager.Web.Services.ManagerService ManagerService

<PageTitle>Game Config</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-cyan-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-4">
                <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Game config</p>
                <StatusTag Text="INI files" />
            </div>

            <button type="button"
                    @onclick="RefreshAsync"
                    class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-cyan-400/25">
                Refresh
            </button>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Game config</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
                Edit the ARK server INI files once the server has been installed and started at least one time.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="@GetStatusMessageClass()">
                @_statusMessage
            </div>
        }

        <div class="space-y-6">
            @foreach (AsaServerManager.Web.Models.GameConfig.GameConfigFileState file in _files)
            {
                <section class="rounded-[1.6rem] border border-cyan-200/12 bg-black/40 p-6 shadow-[0_0_40px_rgba(0,255,255,0.08)] backdrop-blur-md">
                    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
                        <div class="space-y-3">
                            <div class="flex flex-wrap items-center gap-3">
                                <h2 class="text-2xl font-semibold text-white">@file.Title</h2>
                                <StatusTag Text="@file.StateLabel" />
                            </div>

                            <p class="max-w-3xl text-sm leading-6 text-neutral-300">@file.Description</p>
                            <p class="text-xs uppercase tracking-[0.28em] text-neutral-500">@file.FilePath</p>
                        </div>

                        <button type="button"
                                @onclick="() => OpenEditorAsync(file)"
                                disabled="@(!file.CanOpen)"
                                class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-cyan-400/25 disabled:cursor-not-allowed disabled:opacity-50">
                            @(file.Exists ? "Open edit" : "Create and open")
                        </button>
                    </div>
                </section>
            }
        </div>
    </div>
</section>

@if (_editorFile is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/55 p-6 backdrop-blur-sm">
        <div class="flex h-[min(88vh,72rem)] w-full max-w-6xl flex-col rounded-[1.8rem] border border-cyan-200/12 bg-[#05070d]/92 shadow-[0_0_80px_rgba(0,255,255,0.16)] backdrop-blur-xl">
            <div class="flex flex-wrap items-start justify-between gap-4 border-b border-white/10 px-6 py-5">
                <div class="space-y-2">
                    <div class="flex flex-wrap items-center gap-3">
                        <h2 class="text-3xl font-semibold text-white">@_editorFile.Title</h2>
                        <StatusTag Text="@_editorFile.StateLabel" />
                    </div>
                    <p class="max-w-3xl text-sm leading-6 text-neutral-300">@_editorFile.Description</p>
                    <p class="text-xs uppercase tracking-[0.28em] text-neutral-500">@_editorFile.FilePath</p>
                </div>

                <div class="flex flex-wrap gap-3">
                    <button type="button"
                            @onclick="SaveEditorAsync"
                            disabled="@_isSavingEditor"
                            class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-cyan-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                        @(_isSavingEditor ? "Saving..." : "Save")
                    </button>
                    <button type="button"
                            @onclick="CloseEditor"
                            class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10">
                        Close
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_editorMessage))
            {
                <div class="@GetEditorMessageClass()">
                    @_editorMessage
                </div>
            }

            <div class="flex-1 p-6">
                <textarea @bind="_editorContent"
                          @bind:event="oninput"
                          spellcheck="false"
                          class="h-full min-h-[32rem] w-full rounded-[1.3rem] border border-white/10 bg-black/40 p-4 font-mono text-sm leading-6 text-cyan-100 outline-none"></textarea>
            </div>
        </div>
    </div>
}

<ConfirmationDialog IsOpen="@_showRestartDialog"
                    IsBusy="@_isRestartingAsa"
                    Eyebrow="Restart"
                    Title="Do you want to restart the server right now to apply updates?"
                    Message="A restart is required to apply updates. You can also do it later from the Game Shell page."
                    ConfirmText="Yes"
                    CancelText="Later"
                    OnConfirm="RestartAsaAsync"
                    OnCancel="CloseRestartDialog" />

@code {
    private IReadOnlyList<AsaServerManager.Web.Models.GameConfig.GameConfigFileState> _files = Array.Empty<AsaServerManager.Web.Models.GameConfig.GameConfigFileState>();
    private AsaServerManager.Web.Models.GameConfig.GameConfigFileState? _editorFile;
    private string _editorContent = string.Empty;
    private string? _statusMessage;
    private bool _statusIsError;
    private string? _editorMessage;
    private bool _editorMessageIsError;
    private bool _isSavingEditor;
    private bool _showRestartDialog;
    private bool _isRestartingAsa;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _files = await GameConfigService.LoadStatesAsync();
    }

    private async Task OpenEditorAsync(AsaServerManager.Web.Models.GameConfig.GameConfigFileState file)
    {
        try
        {
            _editorFile = file;
            _editorContent = await GameConfigService.LoadEditorContentAsync(file.FilePath);
            _editorMessage = null;
            _editorMessageIsError = false;
            _statusMessage = null;
            _statusIsError = false;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
    }

    private void CloseEditor()
    {
        _editorFile = null;
        _editorContent = string.Empty;
        _editorMessage = null;
        _editorMessageIsError = false;
    }

    private async Task SaveEditorAsync()
    {
        if (_editorFile is null)
        {
            return;
        }

        _isSavingEditor = true;
        bool hadExistingFile = File.Exists(_editorFile.FilePath);

        try
        {
            await GameConfigService.SaveAsync(_editorFile.FilePath, _editorContent);
            _editorMessage = $"{_editorFile.Title} saved.";
            _editorMessageIsError = false;
            await RefreshAsync();
            _editorFile = _files.FirstOrDefault(file => string.Equals(file.FilePath, _editorFile.FilePath, StringComparison.Ordinal)) ?? _editorFile;
            await OpenRestartDialogIfNeededAsync(hadExistingFile);
        }
        catch (Exception exception)
        {
            _editorMessage = exception.Message;
            _editorMessageIsError = true;
        }
        finally
        {
            _isSavingEditor = false;
        }
    }

    private string GetStatusMessageClass()
    {
        return _statusIsError
            ? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
    }

    private string GetEditorMessageClass()
    {
        return _editorMessageIsError
            ? "mx-6 mt-6 rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "mx-6 mt-6 rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
    }

    private async Task OpenRestartDialogIfNeededAsync(bool hadExistingFile)
    {
        if (!hadExistingFile)
        {
            return;
        }

        await ManagerService.RefreshAsync();
        _showRestartDialog = ManagerService.ShouldPromptForRestart;
    }

    private Task RestartAsaAsync()
    {
        _showRestartDialog = false;
        _isRestartingAsa = true;
        _editorMessage = "Restart requested.";
        _editorMessageIsError = false;
        _ = RestartAsaInBackgroundAsync();
        return Task.CompletedTask;
    }

    private async Task RestartAsaInBackgroundAsync()
    {
        try
        {
            _editorMessage = await ManagerService.RestartAsync();
            _editorMessageIsError = false;
        }
        catch (Exception exception)
        {
            _editorMessage = exception.Message;
            _editorMessageIsError = true;
        }
        finally
        {
            _isRestartingAsa = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task CloseRestartDialog()
    {
        _showRestartDialog = false;
        return Task.CompletedTask;
    }
}
