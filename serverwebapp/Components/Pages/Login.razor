@page "/admin/login"
@layout AsaServerManager.Web.Components.Pages.Global.ConnectionLayout
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<section class="w-full max-w-xl rounded-[2rem] border border-white/10 bg-black/30 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Connection</p>
            <StatusTag Text="Login required" />
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Connect to the manager</h1>
            <p class="mt-4 max-w-2xl text-base leading-7 text-neutral-300">
                Sign in to unlock the panel. The default first access is <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">admin</code> / <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">admin</code>.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100">
                @Error
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-2xl border border-cyan-300/20 bg-cyan-400/10 px-5 py-4 text-sm text-cyan-100">
                @Message
            </div>
        }

        <form method="post" action="/auth/login" class="space-y-5">
            <div>
                <label for="username" class="mb-2 block text-sm font-medium text-neutral-300">Username</label>
                <input id="username"
                       name="username"
                       value="admin"
                       autocomplete="username"
                       class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
            </div>

            <div>
                <label for="password" class="mb-2 block text-sm font-medium text-neutral-300">Password</label>
                <input id="password"
                       name="password"
                       type="password"
                       value="admin"
                       autocomplete="current-password"
                       class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
            </div>

            <button type="submit" class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-5 py-2.5 text-sm font-medium text-cyan-100 transition hover:bg-cyan-400/25">
                Connect
            </button>
        </form>
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery]
    private string? Message { get; set; }
}
