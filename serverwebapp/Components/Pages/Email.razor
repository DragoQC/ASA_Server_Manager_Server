@page "/admin/email"
@inject AsaServerManager.Web.Services.EmailService EmailService
@inject AsaServerManager.Web.Services.EmailSettingsService EmailSettingsService

<PageTitle>Email</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-cyan-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="space-y-6">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Email</p>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">SMTP configuration.</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
                Configure SMTP directly in the panel. This page is for outbound email settings only.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100">
                @_statusMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-500/10 px-5 py-4 text-sm text-red-100">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="grid gap-6 xl:grid-cols-[minmax(0,1.5fr)_22rem]">
                <div class="space-y-4 rounded-[1.5rem] border border-white/10 bg-white/5 p-6">
                    <div class="grid gap-4 md:grid-cols-2">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-neutral-300">SMTP host</label>
                            <InputText @bind-Value="_model.SmtpHost" class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
                            <ValidationMessage For="@(() => _model.SmtpHost)" class="mt-2 block text-sm text-red-300" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-neutral-300">SMTP port</label>
                            <InputNumber @bind-Value="_model.SmtpPort" class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
                            <ValidationMessage For="@(() => _model.SmtpPort)" class="mt-2 block text-sm text-red-300" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-neutral-300">Username</label>
                            <InputText @bind-Value="_model.SmtpUsername" class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
                            <ValidationMessage For="@(() => _model.SmtpUsername)" class="mt-2 block text-sm text-red-300" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-neutral-300">Password</label>
                            <InputText @bind-Value="_model.SmtpPassword" type="password" class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
                            <ValidationMessage For="@(() => _model.SmtpPassword)" class="mt-2 block text-sm text-red-300" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-neutral-300">From email</label>
                            <InputText @bind-Value="_model.FromEmail" class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
                            <ValidationMessage For="@(() => _model.FromEmail)" class="mt-2 block text-sm text-red-300" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-neutral-300">From name</label>
                            <InputText @bind-Value="_model.FromName" class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
                            <ValidationMessage For="@(() => _model.FromName)" class="mt-2 block text-sm text-red-300" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="mb-2 block text-sm font-medium text-neutral-300">Test receiver email</label>
                            <InputText @bind-Value="_testReceiver" class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
                        </div>
                    </div>

                    <div class="flex items-center gap-3 pt-2">
                        <button type="submit" class="inline-flex rounded-full border border-emerald-300/20 bg-emerald-400/15 px-5 py-2.5 text-sm font-medium text-emerald-100">
                            Save SMTP settings
                        </button>
                        <button type="button" @onclick="SendTestAsync" class="inline-flex rounded-full border border-cyan-300/20 bg-cyan-400/15 px-5 py-2.5 text-sm font-medium text-cyan-100">
                            Send test email
                        </button>
                    </div>
                </div>

                <aside class="space-y-4 rounded-[1.5rem] border border-white/10 bg-black/20 p-6">
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <p class="text-sm uppercase tracking-[0.28em] text-neutral-500">Storage</p>
                        <p class="mt-3 text-sm text-neutral-300">Stored in SQLite through EF Core once the DB schema is created.</p>
                    </div>

                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <p class="text-sm uppercase tracking-[0.28em] text-neutral-500">Mode</p>
                        <p class="mt-3 text-sm text-neutral-300">SMTP only. No provider-specific API integration.</p>
                    </div>

                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <p class="text-sm uppercase tracking-[0.28em] text-neutral-500">Blazor</p>
                        <p class="mt-3 text-sm text-neutral-300">No controllers required. UI and backend logic live in the same app.</p>
                    </div>
                </aside>
            </div>
        </EditForm>
    </div>
</section>

@code {
    private AsaServerManager.Web.Models.Email.SmtpEmailSettings _model = new();
    private string? _statusMessage;
    private string? _errorMessage;
    private string? _testReceiver;

    protected override async Task OnInitializedAsync()
    {
        _model = await EmailSettingsService.LoadAsync();
        _testReceiver = _model.FromEmail;
    }

    private async Task SaveAsync()
    {
        await EmailSettingsService.SaveAsync(_model);
        _errorMessage = null;
        _statusMessage = "SMTP settings saved.";
    }

    private async Task SendTestAsync()
    {
        try
        {
            string? receiver = string.IsNullOrWhiteSpace(_testReceiver) ? _model.FromEmail : _testReceiver;
            if (string.IsNullOrWhiteSpace(receiver))
            {
                _statusMessage = null;
                _errorMessage = "Add a test receiver email first.";
                return;
            }

            const string subject = "ASA Server Manager SMTP Test";
            const string body = """
<html>
  <body style="font-family:Segoe UI, sans-serif; background:#0a0a0a; color:#f5f5f5; padding:24px;">
    <div style="max-width:640px; margin:0 auto; background:#111827; border:1px solid #1f2937; border-radius:18px; padding:32px;">
      <p style="margin:0 0 12px; font-size:12px; letter-spacing:0.24em; text-transform:uppercase; color:#34d399;">ASA Server Manager</p>
      <h1 style="margin:0 0 16px; font-size:28px; color:#ffffff;">SMTP test successful.</h1>
      <p style="margin:0 0 14px; line-height:1.7; color:#d1d5db;">
        If you see this email, it means your SMTP settings are good and the panel can send mail correctly.
      </p>
      <p style="margin:0; line-height:1.7; color:#9ca3af;">
        Sent from the ASA Server Manager test action.
      </p>
    </div>
  </body>
</html>
""";

            await EmailService.SendAsync(
                _model,
                new EmailMessage(subject, body, receiver));

            _errorMessage = null;
            _statusMessage = $"Test email sent to {receiver}.";
        }
        catch (Exception ex)
        {
            _statusMessage = null;
            _errorMessage = ex.Message;
        }
    }
}
