<article class="rounded-[1.25rem] border border-white/10 bg-white/5 p-5">
    <p class="text-sm uppercase tracking-[0.28em] text-neutral-500">@Label</p>
    <p class="mt-3 text-2xl font-semibold text-white">@Value</p>

    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <p class="mt-3 text-sm text-neutral-400">@Hint</p>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    [Parameter, EditorRequired]
    public string Value { get; set; } = "";

    [Parameter]
    public string? Hint { get; set; }
}
