<div class="rounded-[1.6rem] border border-white/10 bg-white/5 p-6 shadow-[0_0_40px_rgba(0,255,255,0.08)] backdrop-blur">
    <div class="flex items-start justify-between gap-4">
        <div>
            <p class="text-xs uppercase tracking-[0.3em] text-cyan-200/70">@Subtitle</p>
            <h3 class="mt-2 text-2xl font-semibold text-white">@Title</h3>
        </div>
        @if (!string.IsNullOrWhiteSpace(Status))
        {
            <StatusTag Text="@Status" />
        }
    </div>

    <div class="mt-6 flex items-end justify-between gap-4">
        <div class="text-3xl font-semibold text-white drop-shadow-[0_0_16px_rgba(0,255,255,0.35)]">@Stat</div>
        @if (!string.IsNullOrWhiteSpace(StatHint))
        {
            <span class="text-xs uppercase tracking-[0.3em] text-neutral-400">@StatHint</span>
        }
    </div>

    @if (ChildContent is not null)
    {
        <div class="mt-6">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string Subtitle { get; set; } = "";

    [Parameter]
    public string Stat { get; set; } = "--";

    [Parameter]
    public string? StatHint { get; set; }

    [Parameter]
    public string? Status { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
