@if (IsOpen)
{
    <div class="fixed inset-0 z-[120] flex items-center justify-center bg-black/60 p-6 backdrop-blur-sm">
        <div class="w-full max-w-2xl rounded-[1.8rem] border border-cyan-200/12 bg-[#05070d]/94 p-6 shadow-[0_0_80px_rgba(0,255,255,0.16)] backdrop-blur-xl">
            <div class="space-y-4">
                <div class="flex flex-wrap items-center gap-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">@Eyebrow</p>
                    <StatusTag Text="@StatusText" />
                </div>

                <div>
                    <h2 class="text-3xl font-semibold text-white">@Title</h2>
                    @if (ChildContent is null)
                    {
                        <p class="mt-4 text-base leading-7 text-neutral-300">@Message</p>
                    }
                    else
                    {
                        <div class="mt-4">
                            @ChildContent
                        </div>
                    }
                </div>

                <div class="flex flex-wrap justify-end gap-3 pt-2">
                    <button type="button"
                            @onclick="OnCancel"
                            class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10">
                        @CancelText
                    </button>

                    <button type="button"
                            @onclick="OnConfirm"
                            disabled="@IsBusy"
                            class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-5 py-2.5 text-sm font-medium text-cyan-100 transition hover:bg-cyan-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                        @(IsBusy ? $"{ConfirmText}..." : ConfirmText)
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string Eyebrow { get; set; } = "Confirm";

    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string Message { get; set; } = "";

    [Parameter]
    public string StatusText { get; set; } = "Action required";

    [Parameter]
    public string ConfirmText { get; set; } = "Yes";

    [Parameter]
    public string CancelText { get; set; } = "Later";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
