<div class="@GetContainerClass()" tabindex="0" @onfocusout="OnFocusOut" @attributes="AdditionalAttributes">
    <label class="mb-2 block text-sm font-medium text-neutral-300">@Label</label>

    <button type="button"
            @onclick="ToggleOpen"
            class="flex w-full items-center justify-between rounded-2xl border border-cyan-300/20 bg-cyan-400/10 px-4 py-3 text-left text-white shadow-[0_0_18px_rgba(34,211,238,0.15)] outline-none transition hover:border-cyan-300/35 hover:bg-cyan-400/15">
        <span class="truncate">@GetSelectedLabel()</span>
        <span class="@GetChevronClass()">⌄</span>
    </button>

    @if (_isOpen && Options.Count > 0)
    {
        <div class="absolute left-0 right-0 top-full z-[220] mt-2 overflow-hidden rounded-[1.4rem] border border-cyan-300/20 bg-[#07111f]/95 shadow-[0_0_30px_rgba(34,211,238,0.18)] backdrop-blur">
            <div class="max-h-72 overflow-y-auto p-2">
                @foreach (string option in Options)
                {
                    <button type="button"
                            @onmousedown="() => SelectOptionAsync(option)"
                            @onmousedown:preventDefault="true"
                            class="@GetOptionClass(option)">
                        @option
                    </button>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <p class="mt-2 text-sm text-neutral-400">@Hint</p>
    }
</div>

@code {
    private bool _isOpen;

    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<string> Options { get; set; } = Array.Empty<string>();

    [Parameter]
    public string? Hint { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private void ToggleOpen()
    {
        if (Options.Count == 0)
        {
            return;
        }

        _isOpen = !_isOpen;
    }

    private async Task SelectOptionAsync(string option)
    {
        Value = option;
        _isOpen = false;
        await ValueChanged.InvokeAsync(option);
    }

    private Task OnFocusOut(FocusEventArgs _)
    {
        _isOpen = false;
        return Task.CompletedTask;
    }

    private string GetSelectedLabel()
    {
        if (!string.IsNullOrWhiteSpace(Value))
        {
            return Value;
        }

        return Options.Count > 0 ? Options[0] : "No options";
    }

    private string GetContainerClass()
    {
        return _isOpen ? "relative z-[210]" : "relative";
    }

    private string GetChevronClass()
    {
        return _isOpen
            ? "ml-4 text-cyan-200 transition rotate-180"
            : "ml-4 text-cyan-200 transition";
    }

    private string GetOptionClass(string option)
    {
        bool isSelected = string.Equals(option, Value, StringComparison.Ordinal);
        return isSelected
            ? "flex w-full items-center rounded-[1rem] border border-cyan-300/25 bg-cyan-400/15 px-3 py-2 text-left text-sm text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.12)]"
            : "flex w-full items-center rounded-[1rem] border border-transparent px-3 py-2 text-left text-sm text-neutral-200 transition hover:border-cyan-300/20 hover:bg-cyan-400/10 hover:text-cyan-100";
    }
}
