@page "/admin/settings"
@inject asa_server_node_api.Services.AuthService AuthService
@inject NavigationManager NavigationManager
@using asa_server_node_api.Constants
@using asa_server_node_api.Models.Auth

<PageTitle>Settings</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-cyan-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Settings</p>
            <StatusTag Text="Account" />
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Settings</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
                Update account and remote access settings for this manager panel.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="rounded-2xl border border-cyan-300/20 bg-cyan-400/10 px-5 py-4 text-sm text-cyan-100">
                @_message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100">
                @_error
            </div>
        }

        <div class="max-w-2xl rounded-[1.6rem] border border-white/10 bg-black/30 p-6 shadow-[0_0_30px_rgba(0,255,255,0.08)] backdrop-blur-md">
            <div class="space-y-6">
                <div class="flex flex-wrap items-center gap-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Account</p>
                    <StatusTag Text="Password" />
                </div>

                <div>
                    <h2 class="text-2xl font-semibold text-white">Reset password</h2>
                    <p class="mt-3 text-sm leading-6 text-neutral-300">
                        Open the password reset page when you want to change the admin password.
                    </p>
                </div>

                <button type="button"
                        @onclick="OpenResetPasswordPage"
                        class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-5 py-2.5 text-sm font-medium text-cyan-100 transition hover:bg-cyan-400/25">
                    Open reset password
                </button>
            </div>
        </div>

        <div class="max-w-2xl rounded-[1.6rem] border border-white/10 bg-black/30 p-6 shadow-[0_0_30px_rgba(0,255,255,0.08)] backdrop-blur-md">
            <div class="space-y-6">
                <div class="flex flex-wrap items-center gap-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Remote API</p>
                    <StatusTag Text="Keys" />
                </div>

                <div>
                    <h2 class="text-2xl font-semibold text-white">API keys</h2>
                    <p class="mt-3 text-sm leading-6 text-neutral-300">
                        Manage the app API key used for admin calls and the control API key received from VPN invitation flow.
                    </p>
                </div>

                <TextField Label="App API key"
                           @bind-Value="_appApiKey"
                           Hint="You can paste your own key or generate a new one for this app."
                           autocomplete="off" />

                <div class="flex flex-wrap gap-3">
                    <button type="button"
                            @onclick="GenerateAppApiKey"
                            class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10">
                        Generate key
                    </button>

                    <button type="button"
                            @onclick="SaveAppApiKeyAsync"
                            class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-5 py-2.5 text-sm font-medium text-cyan-100 transition hover:bg-cyan-400/25">
                        Save API key
                    </button>
                </div>

                <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300">Stored keys</p>
                        <StatusTag Text="@($"{_apiKeys.Count} keys")" />
                    </div>

                    @if (_apiKeys.Count == 0)
                    {
                        <p class="mt-4 text-sm leading-6 text-neutral-300">No API keys stored yet.</p>
                    }
                    else
                    {
                        <div class="mt-4 space-y-3">
                            @foreach (StoredApiKey apiKey in _apiKeys)
                            {
                                <div class="rounded-[1.2rem] border border-white/10 bg-black/20 p-4">
                                    <div class="flex flex-wrap items-center justify-between gap-3">
                                        <div class="flex flex-wrap items-center gap-3">
                                            <StatusTag Text="@apiKey.Type" />
                                            <p class="text-xs uppercase tracking-[0.24em] text-neutral-400">Updated @apiKey.ModifiedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
                                        </div>

                                        @if (string.Equals(apiKey.Type, ApiKeyTypeConstants.Control, StringComparison.Ordinal))
                                        {
                                            <button type="button"
                                                    @onclick="() => DeleteApiKeyAsync(apiKey.Type)"
                                                    class="inline-flex rounded-full border border-red-300/20 bg-red-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-red-100 transition hover:bg-red-400/20">
                                                Delete
                                            </button>
                                        }
                                    </div>

                                    <textarea value="@apiKey.ApiKey"
                                              readonly
                                              class="mt-4 h-24 w-full rounded-[1rem] border border-white/10 bg-black/40 p-3 font-mono text-sm leading-6 text-cyan-100 outline-none"></textarea>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private string? _message;
    private string? _error;
    private string? _appApiKey;
    private IReadOnlyList<StoredApiKey> _apiKeys = Array.Empty<StoredApiKey>();

    protected override async Task OnInitializedAsync()
    {
        await LoadApiKeysAsync();
    }

    private void OpenResetPasswordPage()
    {
        NavigationManager.NavigateTo("/admin/reset-password");
    }

    private void GenerateAppApiKey()
    {
        _appApiKey = asa_server_node_api.Services.AuthService.GenerateRemoteApiKey();
        _message = "Generated a new app API key. Save it to apply.";
        _error = null;
    }

    private async Task SaveAppApiKeyAsync()
    {
        _message = null;
        _error = null;

        if (string.IsNullOrWhiteSpace(_appApiKey))
        {
            _error = "API key is required.";
            return;
        }

        await AuthService.SaveAppApiKeyAsync(_appApiKey);
        await LoadApiKeysAsync();
        _message = "App API key updated.";
    }

    private async Task DeleteApiKeyAsync(string type)
    {
        _message = null;
        _error = null;

        await AuthService.DeleteApiKeyAsync(type);
        await LoadApiKeysAsync();
        _message = $"{type} API key deleted.";
    }

    private async Task LoadApiKeysAsync()
    {
        _appApiKey = await AuthService.LoadAppApiKeyAsync();
        _apiKeys = await AuthService.LoadApiKeysAsync();
    }
}
