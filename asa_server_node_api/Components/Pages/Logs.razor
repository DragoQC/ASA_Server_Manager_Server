@page "/admin/logs"
@implements IAsyncDisposable
@using asa_server_node_api.Models.Asa
@using asa_server_node_api.Models.AsaLogs
@inject asa_server_node_api.Services.LogsService LogsService

<PageTitle>Logs</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-cyan-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-4">
                <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Logs</p>
            </div>

        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Logs</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
                Live service status and recent logs for <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">asa.service</code>. This page refreshes every 5 seconds.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100">
                @_loadError
            </div>
        }

        <div class="space-y-6">
            @foreach (LogSectionSnapshot logSection in GetSections())
            {
                <section class="rounded-[1.6rem] border border-white/10 bg-black/40 p-6 shadow-[0_0_30px_rgba(0,255,255,0.08)]">
                    <div class="space-y-3">
                        <div class="flex flex-wrap items-center gap-3">
                            <h2 class="text-2xl font-semibold text-white">@logSection.Title</h2>
                            <StatusTag Text="@(logSection.IsAvailable ? "OK" : "Missing")" />
                        </div>

                        <p class="text-sm leading-6 text-neutral-300">@logSection.Description</p>
                    </div>

                    <pre class="mt-5 h-[20rem] overflow-auto rounded-[1.2rem] border border-white/10 bg-[#05070d] p-4 font-mono text-sm leading-6 whitespace-pre-wrap text-cyan-100 shadow-[inset_0_0_25px_rgba(34,211,238,0.08)]">@logSection.Content</pre>
                </section>
            }
        </div>
    </div>
</section>

@code {
    private AsaLogsSnapshot _snapshot = new(
        AsaServiceStatus.Unknown(),
        new LogSectionSnapshot("Service status", "Live systemctl status output for asa.service.", "Loading...", false),
        new LogSectionSnapshot("Web app journal", "Recent journalctl output for asa-webapp.", "Loading...", false),
        new LogSectionSnapshot("WireGuard journal", "Recent journalctl output for wg-quick@wg0.", "Loading...", false),
        new LogSectionSnapshot("SMB mount journal", "Recent journalctl output for the SMB/CIFS cluster mount at opt-asa-cluster.mount.", "Loading...", false),
        DateTimeOffset.UtcNow);
    private CancellationTokenSource? _refreshLoopCancellationTokenSource;
    private bool _isRefreshing;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _refreshLoopCancellationTokenSource = new CancellationTokenSource();
        _ = RunRefreshLoopAsync(_refreshLoopCancellationTokenSource.Token);
    }

    private async Task RefreshAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        _isRefreshing = true;

        try
        {
            _snapshot = await LogsService.LoadAsync();
            _loadError = null;
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
        }
        finally
        {
            _isRefreshing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using PeriodicTimer timer = new(TimeSpan.FromSeconds(5));

            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshAsync();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private IReadOnlyList<LogSectionSnapshot> GetSections()
    {
        return
        [
            _snapshot.StatusSection,
            _snapshot.WebAppJournalSection,
            _snapshot.WireGuardJournalSection,
            _snapshot.SmbJournalSection
        ];
    }

    public ValueTask DisposeAsync()
    {
        if (_refreshLoopCancellationTokenSource is not null)
        {
            _refreshLoopCancellationTokenSource.Cancel();
            _refreshLoopCancellationTokenSource.Dispose();
            _refreshLoopCancellationTokenSource = null;
        }

        return ValueTask.CompletedTask;
    }
}
