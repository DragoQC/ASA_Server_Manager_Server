@page "/"
@implements IAsyncDisposable
@inject asa_server_node_api.Services.ServerConfigService ServerConfigService
@inject asa_server_node_api.Services.ManagerService ManagerService
@inject asa_server_node_api.Services.PlayerCountMonitorService PlayerCountMonitorService

<PageTitle>ASA Server</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-cyan-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-4">
                <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Public status</p>
                <StatusTag Text="@ManagerService.CurrentStatus.DisplayText" />
            </div>

            <a href="/admin/login"
               class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-cyan-400/25">
                Admin login
            </a>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">@DisplayServerName</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
                Public server information page for this ASA instance.
            </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-5">
            <PlayerCountCard Current="@_playerCountSnapshot.CurrentPlayers"
                             Max="@_playerCountSnapshot.MaxPlayers"
                             IsLoading="@IsPlayerCountLoading" />
            <DashboardValueCard Title="Server name"
                                Subtitle="Public"
                                Value="@DisplayServerName"
                                Description="Current configured ASA server name." />
            <DashboardValueCard Title="Server state"
                                Subtitle="systemd"
                                Value="@ManagerService.CurrentStatus.DisplayText"
                                Description="Current asa.service state." />
            <DashboardValueCard Title="Time up"
                                Subtitle="systemd"
                                Value="@ManagerService.CurrentStatus.UptimeText"
                                Description="Current uptime from asa.service when available." />
            <DashboardValueCard Title="Mods"
                                Subtitle="Configuration"
                                Value="@ModsCountValue"
                                Description="Configured mod count from asa.env." />
        </div>
    </div>
</section>

@code {
    private asa_server_node_api.Models.ServerConfig.ServerConfigSettings _settings = asa_server_node_api.Models.ServerConfig.ServerConfigSettings.Default();
    private asa_server_node_api.Models.Players.PlayerCountSnapshot _playerCountSnapshot =
        asa_server_node_api.Models.Players.PlayerCountSnapshot.Default();
    private List<string> _mods = [];
    private bool _isLoadingConfig = true;

    private bool IsPlayerCountLoading => string.Equals(_playerCountSnapshot.StatusLabel, "Waiting", StringComparison.OrdinalIgnoreCase);
    private string DisplayServerName => _isLoadingConfig ? "Loading..." : _settings.ServerName;
    private string ModsCountValue => _isLoadingConfig ? "Loading..." : _mods.Count.ToString();

    protected override void OnInitialized()
    {
        _playerCountSnapshot = PlayerCountMonitorService.GetSnapshot();
        PlayerCountMonitorService.Changed += OnPlayerCountChanged;
        ManagerService.Changed += OnManagerChanged;
        _ = LoadPublicDataAsync();
        _ = PlayerCountMonitorService.RefreshNowAsync();
        _ = ManagerService.EnsureStartedAsync();
    }

    private void OnPlayerCountChanged()
    {
        _ = InvokeAsync(() =>
        {
            _playerCountSnapshot = PlayerCountMonitorService.GetSnapshot();
            StateHasChanged();
        });
    }

    private void OnManagerChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadPublicDataAsync()
    {
        try
        {
            _settings = await ServerConfigService.LoadAsync();
            _mods = _settings.ModIds
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .ToList();
        }
        finally
        {
            _isLoadingConfig = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public ValueTask DisposeAsync()
    {
        PlayerCountMonitorService.Changed -= OnPlayerCountChanged;
        ManagerService.Changed -= OnManagerChanged;
        return ValueTask.CompletedTask;
    }
}
