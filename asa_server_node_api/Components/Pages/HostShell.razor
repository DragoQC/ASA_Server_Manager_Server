@page "/admin/host-shell"

<PageTitle>Host Shell</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-cyan-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="flex flex-wrap items-center gap-4">
        <p class="text-xs font-semibold uppercase tracking-[0.45em] text-cyan-300">Shell</p>
    </div>

    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white md:text-5xl">Host shell</h1>

    <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
        Browser shell for the machine running the panel. Commands execute as the web app user on that host.
    </p>

    <div class="mt-8">
        <ShellConsolePanel SessionKey="host"
                           SessionTitle="Host shell"
                           WorkingDirectory="@Environment.GetFolderPath(Environment.SpecialFolder.UserProfile)"
                           Description="Use this for host checks, package inspection, file browsing, and Debian-level commands." />
    </div>
</section>
