@page "/admin/cluster"
@page "/admin/vpn"
@inject asa_server_node_api.Services.InstallStateService InstallStateService
@inject asa_server_node_api.Services.VpnConfigService VpnConfigService
@inject asa_server_node_api.Services.SmbConfigService SmbConfigService
@using asa_server_node_api.Contracts.Api.Admin

<PageTitle>Cluster</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-app-200/10 bg-gradient-to-br from-black/35 via-[#0b0b15]/30 to-[#0b1325]/35 p-8 shadow-[0_0_70px_rgba(0,255,255,0.12)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-app-300">Cluster</p>
            <StatusTag Text="Client setup" />
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Cluster client</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
                Prepare this node for cluster networking and shared storage. The control app must be reachable from the public internet for invite links to work.
            </p>
            <p class="mt-3 max-w-3xl text-sm leading-6 text-app-200/80">
                Use the VPN invite to fetch <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">wg0.conf</code>. Use the SMB invite to fetch the CIFS client mount config and apply it to <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">/etc/fstab</code>.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="@GetStatusMessageClass()">
                @_statusMessage
            </div>
        }

        <section class="rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
            <div class="space-y-6">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div class="flex flex-wrap items-center gap-3">
                        <h2 class="text-3xl font-semibold text-white">Cluster client tools</h2>
                        <StatusTag Text="@(_hasClusterClientInstall ? "Ready" : "Install first")" />
                        <StatusTag Text="@(_hasWireGuardClientInstall ? "WireGuard installed" : "WireGuard missing")" />
                        <StatusTag Text="@(_hasSmbClientInstall ? "SMB installed" : "SMB missing")" />
                    </div>

                    <p class="max-w-md text-sm leading-6 text-neutral-300">
                        If you want to configure your own stack manually, do not enable this. It can mix with your own setup and make things worse instead of helping.
                    </p>
                </div>

                @if (!_hasClusterClientInstall)
                {
                    <div class="flex flex-wrap gap-3">
                        <button type="button"
                                @onclick="OpenEnableDialog"
                                disabled="@IsInstallingClusterClient"
                                class="inline-flex rounded-full border border-app-300/30 bg-app-400/15 px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-app-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-app-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                            @(IsInstallingClusterClient ? "Preparing cluster client..." : "Enable cluster client")
                        </button>
                    </div>
                }

                <p class="text-sm leading-6 text-neutral-300">
                    This installs the WireGuard and SMB/CIFS client packages only. After that, use the invite links below to fetch the real VPN and SMB config from the control app.
                </p>
            </div>
        </section>

        <section class="rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
            <div class="space-y-6">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div class="flex flex-wrap items-center gap-3">
                        <h2 class="text-3xl font-semibold text-white">VPN config</h2>
                        <StatusTag Text="@(_hasWireGuardConfig ? "wg0.conf present" : "wg0.conf missing")" />
                    </div>

                    <button type="button"
                            @onclick="OpenVpnInfoDialog"
                            class="ml-auto inline-flex h-10 w-10 shrink-0 items-center justify-center self-start rounded-full border border-cyan-300/20 bg-cyan-400/15 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-400/25"
                            aria-label="VPN config help">
                        ?
                    </button>
                </div>

                <TextField Label="VPN invite URL"
                           @bind-Value="_vpnInviteUrl"
                           placeholder="https://control.dragoqc.com/api/vpn/invite/your-one-time-key"
                           Hint="Paste the full VPN invite link from the control app."
                           disabled="@(!_hasClusterClientInstall || _isFetchingVpnConfig)"
                           autocomplete="off" />

                <div class="flex flex-wrap gap-3">
                    <button type="button"
                            @onclick="GetVpnConfigAsync"
                            disabled="@(!_hasClusterClientInstall || _isFetchingVpnConfig || string.IsNullOrWhiteSpace(_vpnInviteUrl))"
                            class="inline-flex rounded-full border border-app-300/30 bg-app-400/15 px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-app-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-app-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                        @(_isFetchingVpnConfig ? "Getting config..." : "Get config")
                    </button>
                </div>

                <div class="rounded-[1.6rem] border border-white/10 bg-white/5 p-6">
                    <div class="flex flex-wrap items-center gap-3">
                        <h3 class="text-2xl font-semibold text-white">wg0.conf</h3>
                        <StatusTag Text="@(_hasWireGuardConfig ? "Present" : "Missing")" />
                    </div>

                    <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-300">
                        Current local WireGuard client configuration from <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">/opt/asa/vpn/wg0.conf</code>. The system link points <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">/etc/wireguard/wg0.conf</code> to this file.
                    </p>

                    <textarea value="@(_wireGuardConfigContent ?? string.Empty)"
                              readonly
                              placeholder="No wg0.conf file yet."
                              class="mt-5 h-[28rem] w-full rounded-[1.3rem] border border-white/10 bg-black/40 p-4 font-mono text-sm leading-6 text-app-100 outline-none"></textarea>
                </div>
            </div>
        </section>

        <section class="rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
            <div class="space-y-6">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div class="flex flex-wrap items-center gap-3">
                        <h2 class="text-3xl font-semibold text-white">SMB config</h2>
                        <StatusTag Text="@(_hasSmbClientConfig ? "client.mount.cifs.conf present" : "client.mount.cifs.conf missing")" />
                    </div>

                    <button type="button"
                            @onclick="OpenSmbInfoDialog"
                            class="ml-auto inline-flex h-10 w-10 shrink-0 items-center justify-center self-start rounded-full border border-cyan-300/20 bg-cyan-400/15 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-400/25"
                            aria-label="SMB config help">
                        ?
                    </button>
                </div>

                <TextField Label="SMB invite URL"
                           @bind-Value="_smbInviteUrl"
                           placeholder="https://control.dragoqc.com/api/smb/invite/your-one-time-key"
                           Hint="@GetSmbInviteHint()"
                           disabled="@(!CanFetchSmbConfig)"
                           autocomplete="off" />

                <div class="flex flex-wrap gap-3">
                    <button type="button"
                            @onclick="GetSmbConfigAsync"
                            disabled="@(!CanFetchSmbConfig || string.IsNullOrWhiteSpace(_smbInviteUrl))"
                            class="inline-flex rounded-full border border-app-300/30 bg-app-400/15 px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-app-100 shadow-[0_0_18px_rgba(34,211,238,0.3)] transition hover:bg-app-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                        @(_isFetchingSmbConfig ? "Getting config..." : "Get config")
                    </button>
                </div>

                <div class="rounded-[1.6rem] border border-white/10 bg-white/5 p-6">
                    <div class="flex flex-wrap items-center gap-3">
                        <h3 class="text-2xl font-semibold text-white">client.mount.cifs.conf</h3>
                        <StatusTag Text="@(_hasSmbClientConfig ? "Present" : "Missing")" />
                    </div>

                    <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-300">
                        Current local SMB client config from <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">/opt/asa/smb/client.mount.cifs.conf</code>. Applying the SMB invite updates <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">/etc/fstab</code> from this saved file.
                    </p>

                    <textarea value="@(_smbClientConfigContent ?? string.Empty)"
                              readonly
                              placeholder="No client.mount.cifs.conf file yet."
                              class="mt-5 h-[18rem] w-full rounded-[1.3rem] border border-white/10 bg-black/40 p-4 font-mono text-sm leading-6 text-app-100 outline-none"></textarea>
                </div>
            </div>
        </section>
    </div>
</section>

<ConfirmationDialog IsOpen="@_showEnableDialog"
                    IsBusy="@IsInstallingClusterClient"
                    Eyebrow="Cluster"
                    Title="Do you want to enable the cluster client on this node?"
                    Message="If you continue, this will install the WireGuard and SMB/CIFS client packages and prepare the node to receive its cluster configuration from the control app."
                    ConfirmText="Enable cluster client"
                    CancelText="Cancel"
                    OnConfirm="EnableClusterClientAsync"
                    OnCancel="CloseEnableDialog" />

<ConfirmationDialog IsOpen="@_showVpnInfoDialog"
                    Eyebrow="VPN config"
                    Title="Why is WireGuard used here?"
                    ConfirmText="Close"
                    HideCancelButton="true"
                    OnConfirm="CloseVpnInfoDialog"
                    OnCancel="CloseVpnInfoDialog">
    <ChildContent>
        <div class="space-y-4 text-sm leading-6 text-neutral-200">
            <p>
                You can get the VPN config from an invite link generated by the control panel. This page fetches that link and saves the returned
                <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">wg0.conf</code>
                for this node.
            </p>
            <p>
                WireGuard is the VPN used for cluster networking here. It is a good fit because we only need a simple one-to-one machine connection between the control side and each ASA server node.
            </p>
            <p>
                We use the VPN so the cluster traffic and storage traffic can go through a private network path instead of trying to expose internal services directly to the public internet.
            </p>
        </div>
    </ChildContent>
</ConfirmationDialog>

<ConfirmationDialog IsOpen="@_showSmbInfoDialog"
                    Eyebrow="SMB config"
                    Title="Why does SMB depend on the VPN?"
                    ConfirmText="Close"
                    HideCancelButton="true"
                    OnConfirm="CloseSmbInfoDialog"
                    OnCancel="CloseSmbInfoDialog">
    <ChildContent>
        <div class="space-y-4 text-sm leading-6 text-neutral-200">
            <p>
                You can get the SMB config from an invite link generated by the control panel. This page fetches that link, saves the returned client mount config, and applies it to
                <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">/etc/fstab</code>.
            </p>
            <p>
                SMB depends on the VPN because the shared cluster folder is only meant to be reachable through the private WireGuard network. Without the VPN, the SMB/CIFS share will not be reachable in the expected safe path.
            </p>
            <p>
                ARK clustering needs each server to read and write to the exact same cluster folder path so cluster data can be shared correctly across machines.
            </p>
            <p>
                That is why this setup uses both a VPN and an SMB share: WireGuard connects the machines together, and SMB gives each server the same shared folder to use for cluster data.
            </p>
        </div>
    </ChildContent>
</ConfirmationDialog>

@code {
    private bool _showEnableDialog;
    private bool _showVpnInfoDialog;
    private bool _showSmbInfoDialog;
    private bool _isFetchingVpnConfig;
    private bool _isFetchingSmbConfig;
    private bool _hasClusterClientInstall;
    private bool _hasWireGuardClientInstall;
    private bool _hasSmbClientInstall;
    private bool _hasWireGuardConfig;
    private bool _hasSmbClientConfig;
    private string? _wireGuardConfigContent;
    private string? _smbClientConfigContent;
    private string? _vpnInviteUrl;
    private string? _smbInviteUrl;
    private string? _statusMessage;
    private bool _statusIsError;
    private bool IsInstallingClusterClient => InstallStateService.IsInstallingClusterClient;
    private bool CanFetchSmbConfig => _hasClusterClientInstall && _hasWireGuardConfig && !_isFetchingSmbConfig;

    protected override async Task OnInitializedAsync()
    {
        await RefreshClusterStateAsync();
    }

    private void OpenEnableDialog()
    {
        _showEnableDialog = true;
    }

    private Task OpenVpnInfoDialog()
    {
        _showVpnInfoDialog = true;
        return Task.CompletedTask;
    }

    private Task CloseVpnInfoDialog()
    {
        _showVpnInfoDialog = false;
        return Task.CompletedTask;
    }

    private Task OpenSmbInfoDialog()
    {
        _showSmbInfoDialog = true;
        return Task.CompletedTask;
    }

    private Task CloseSmbInfoDialog()
    {
        _showSmbInfoDialog = false;
        return Task.CompletedTask;
    }

    private Task CloseEnableDialog()
    {
        if (IsInstallingClusterClient)
        {
            return Task.CompletedTask;
        }

        _showEnableDialog = false;
        return Task.CompletedTask;
    }

    private Task EnableClusterClientAsync()
    {
        _showEnableDialog = false;
        _statusMessage = "Installing cluster client tools and preparing the node...";
        _statusIsError = false;
        _ = EnableClusterClientInBackgroundAsync();
        return Task.CompletedTask;
    }

    private async Task EnableClusterClientInBackgroundAsync()
    {
        try
        {
            _statusMessage = await InstallStateService.InstallClusterClientAsync();
            _statusIsError = false;
            await RefreshClusterStateAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task GetVpnConfigAsync()
    {
        _isFetchingVpnConfig = true;
        _statusMessage = "Requesting VPN configuration from the control server...";
        _statusIsError = false;

        try
        {
            InviteRemoteServerResponse result = await VpnConfigService.ClaimInviteAsync(_vpnInviteUrl);
            _statusMessage = result.Message;
            _statusIsError = !result.Accepted;

            if (result.Accepted)
            {
                _vpnInviteUrl = string.Empty;
                await RefreshClusterStateAsync();
            }
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isFetchingVpnConfig = false;
        }
    }

    private async Task GetSmbConfigAsync()
    {
        _isFetchingSmbConfig = true;
        _statusMessage = "Requesting SMB configuration from the control server...";
        _statusIsError = false;

        try
        {
            _statusMessage = await SmbConfigService.ClaimInviteAsync(_smbInviteUrl);
            _statusIsError = false;
            _smbInviteUrl = string.Empty;
            await RefreshClusterStateAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isFetchingSmbConfig = false;
        }
    }

    private async Task RefreshClusterStateAsync()
    {
        _hasWireGuardClientInstall = InstallStateService.HasWireGuardClientInstall();
        _hasSmbClientInstall = InstallStateService.HasSmbClientInstall();
        _hasClusterClientInstall = InstallStateService.HasClusterClientInstall();
        _hasWireGuardConfig = File.Exists(asa_server_node_api.Constants.InstallStateConstants.WireGuardConfigFilePath);
        _hasSmbClientConfig = File.Exists(asa_server_node_api.Constants.InstallStateConstants.SmbClientConfigFilePath);
        _wireGuardConfigContent = await VpnConfigService.LoadConfigContentAsync();
        _smbClientConfigContent = await SmbConfigService.LoadConfigContentAsync();
    }

    private string GetStatusMessageClass()
    {
        return _statusIsError
            ? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "rounded-2xl border border-app-300/20 bg-app-400/10 px-5 py-4 text-sm text-app-100";
    }

    private string GetSmbInviteHint()
    {
        if (!_hasClusterClientInstall)
        {
            return "Install the cluster client tools first.";
        }

        if (!_hasWireGuardConfig)
        {
            return "Fetch and apply wg0.conf first. SMB only works after WireGuard is configured.";
        }

        return "Paste the full SMB invite link from the control app.";
    }
}
