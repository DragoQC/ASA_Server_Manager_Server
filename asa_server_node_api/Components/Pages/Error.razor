@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-app-300/20 bg-app-400/10 p-8 text-app-50 shadow-[0_0_40px_rgba(0,255,255,0.08)] backdrop-blur-[2px]">
    <p class="text-[0.7rem] uppercase tracking-[0.35em] text-app-100/80">Server Node API</p>
    <h1 class="mt-3 text-3xl font-semibold">Error</h1>
    <h2 class="mt-2 text-lg text-app-100/90">An error occurred while processing your request.</h2>

    <p class="mt-6 max-w-2xl text-sm leading-7 text-neutral-300">
        Reload the page or check the app logs if this keeps happening.
    </p>

    @if (ShowRequestId)
    {
        <p class="mt-4 text-sm text-app-100/90">
            <strong>Request ID:</strong>
            <code class="rounded bg-black/20 px-2 py-1 text-app-50">@RequestId</code>
        </p>
    }
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
