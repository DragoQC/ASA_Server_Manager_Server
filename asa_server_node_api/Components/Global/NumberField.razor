<div>
    <label class="mb-2 block text-sm font-medium text-neutral-300">@Label</label>
    <input type="number"
           value="@Value"
           @oninput="OnNumberChanged"
           class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none"
           @attributes="AdditionalAttributes" />

    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <p class="mt-2 text-sm text-neutral-400">@Hint</p>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    [Parameter]
    public int Value { get; set; }

    [Parameter]
    public EventCallback<int> ValueChanged { get; set; }

    [Parameter]
    public string? Hint { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private Task OnNumberChanged(ChangeEventArgs eventArgs)
    {
        int nextValue = int.TryParse(eventArgs.Value?.ToString(), out int parsedValue) ? parsedValue : 0;
        Value = nextValue;
        return ValueChanged.InvokeAsync(nextValue);
    }
}
