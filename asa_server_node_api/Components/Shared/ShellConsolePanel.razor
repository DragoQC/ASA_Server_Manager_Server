@using Microsoft.JSInterop
@using asa_server_node_api.Models.Shell
@implements IDisposable
@inject asa_server_node_api.Services.ShellConsoleService ShellConsoleService
@inject IJSRuntime JSRuntime

<section class="space-y-6">
    <div class="rounded-[1.6rem] border border-white/10 bg-black/40 p-4 shadow-[0_0_30px_rgba(0,255,255,0.08)]">
        <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap items-center gap-3">
                <StatusTag Text="@(_snapshot.IsRunning ? (_snapshot.IsBusy ? "Busy" : "Running") : "Stopped")" />
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs uppercase tracking-[0.2em] text-neutral-300">
                    App user shell
                </span>
            </div>

            <div class="flex flex-wrap gap-2">
                <button type="button"
                        @onclick="ClearAsync"
                        disabled="@_isRestarting"
                        class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                    Clear
                </button>
                <button type="button"
                        @onclick="RestartAsync"
                        disabled="@_isRestarting"
                        class="inline-flex rounded-full border border-amber-300/20 bg-amber-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-amber-100 transition hover:bg-amber-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                    @if (_isRestarting)
                    {
                        <span class="inline-flex items-center gap-2">
                            <span class="h-3 w-3 animate-spin rounded-full border border-amber-100/30 border-t-amber-100"></span>
                            Restarting
                        </span>
                    }
                    else
                    {
                        <span>Restart shell</span>
                    }
                </button>
            </div>
        </div>

        <pre @ref="_transcriptRef" class="h-[32rem] overflow-auto rounded-[1.2rem] border border-white/10 bg-[#05070d] p-4 font-mono text-sm leading-6 whitespace-pre-wrap text-cyan-100 shadow-[inset_0_0_25px_rgba(34,211,238,0.08)]">@_snapshot.Transcript</pre>
        <label class="py-2 block text-sm font-medium text-neutral-300">Command</label>
        <p class="pb-3 text-sm text-cyan-200/80">Current folder: @_snapshot.WorkingDirectory</p>
        <div class="flex flex-col gap-3 md:flex-row">
            <input @ref="_commandInputRef"
                   value="@_command"
                   @oninput="OnCommandInput"
                   @onkeydown="OnCommandKeyDown"
                   class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 font-mono text-white outline-none"
                   placeholder="Type a shell command" />
            <button type="button"
                    @onclick="RunAsync"
                    disabled="@(_isRestarting || _snapshot.IsBusy || string.IsNullOrWhiteSpace(_command))"
                    class="inline-flex items-center justify-center rounded-full border border-cyan-300/20 bg-cyan-400/15 px-5 py-3 text-sm font-medium text-cyan-100 transition hover:bg-cyan-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                Run
            </button>
        </div>
        @if (_autocompleteSuggestions.Count > 1)
        {
            <p class="mt-3 text-sm text-cyan-200/80">Suggestions: @string.Join("  ", _autocompleteSuggestions)</p>
        }
        <p class="mt-3 text-sm text-neutral-400">@Description</p>
    </div>
</section>

@code {
    private ShellConsoleSnapshot _snapshot = default!;
    private string _command = string.Empty;
    private readonly List<string> _history = [];
    private IReadOnlyList<string> _autocompleteSuggestions = Array.Empty<string>();
    private int _historyIndex;
    private string _draftCommand = string.Empty;
    private bool _isRestarting;
    private DotNetObjectReference<ShellConsolePanel>? _dotNetReference;
    private ElementReference _commandInputRef;
    private ElementReference _transcriptRef;
    private DateTimeOffset _lastRenderedUpdateUtc;

    [Parameter, EditorRequired]
    public string SessionKey { get; set; } = "";

    [Parameter, EditorRequired]
    public string SessionTitle { get; set; } = "";

    [Parameter, EditorRequired]
    public string WorkingDirectory { get; set; } = "/";

    [Parameter, EditorRequired]
    public string Description { get; set; } = "";

    protected override void OnInitialized()
    {
        _snapshot = ShellConsoleService.GetSnapshot(SessionKey, WorkingDirectory);
        _historyIndex = 0;
        ShellConsoleService.SessionChanged += OnSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetReference = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("shellConsole.registerAutocomplete", _commandInputRef, _dotNetReference);
        }

        if (firstRender || _snapshot.UpdatedAtUtc != _lastRenderedUpdateUtc)
        {
            _lastRenderedUpdateUtc = _snapshot.UpdatedAtUtc;
            await JSRuntime.InvokeVoidAsync("shellConsole.scrollToBottom", _transcriptRef);
        }
    }

    private void OnSessionChanged(string key)
    {
        if (!string.Equals(key, SessionKey, StringComparison.Ordinal))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            _snapshot = ShellConsoleService.GetSnapshot(SessionKey, WorkingDirectory);
            StateHasChanged();
        });
    }

    private async Task RunAsync()
    {
        string command = _command.Trim();
        if (string.IsNullOrWhiteSpace(command))
        {
            return;
        }

        _history.Add(command);
        _historyIndex = _history.Count;
        _draftCommand = string.Empty;
        _command = string.Empty;
        _autocompleteSuggestions = Array.Empty<string>();
        await ShellConsoleService.ExecuteAsync(SessionKey, WorkingDirectory, command);
        _snapshot = ShellConsoleService.GetSnapshot(SessionKey, WorkingDirectory);
    }

    private void OnCommandInput(ChangeEventArgs args)
    {
        _command = args.Value?.ToString() ?? string.Empty;
        _autocompleteSuggestions = Array.Empty<string>();
        if (_historyIndex >= _history.Count)
        {
            _draftCommand = _command;
        }
    }

    private async Task OnCommandKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await RunAsync();
            return;
        }

        if (_history.Count == 0)
        {
            return;
        }

        if (args.Key == "ArrowUp")
        {
            if (_historyIndex == _history.Count)
            {
                _draftCommand = _command;
            }

            if (_historyIndex > 0)
            {
                _historyIndex--;
                _command = _history[_historyIndex];
            }

            return;
        }

        if (args.Key == "ArrowDown")
        {
            if (_historyIndex < _history.Count)
            {
                _historyIndex++;
            }

            _command = _historyIndex == _history.Count
                ? _draftCommand
                : _history[_historyIndex];
        }
    }

    private Task ClearAsync()
    {
        ShellConsoleService.Clear(SessionKey, WorkingDirectory);
        ResetCommandState();
        _snapshot = ShellConsoleService.GetSnapshot(SessionKey, WorkingDirectory);
        return Task.CompletedTask;
    }

    private async Task RestartAsync()
    {
        _isRestarting = true;
        ResetCommandState();

        try
        {
            await ShellConsoleService.RestartAsync(SessionKey, WorkingDirectory);
            _snapshot = ShellConsoleService.GetSnapshot(SessionKey, WorkingDirectory);
        }
        finally
        {
            _isRestarting = false;
        }
    }

    private void ResetCommandState()
    {
        _command = string.Empty;
        _draftCommand = string.Empty;
        _history.Clear();
        _historyIndex = 0;
        _autocompleteSuggestions = Array.Empty<string>();
    }

    [JSInvokable]
    public Task HandleTabAutocomplete()
    {
        ShellAutocompleteResult result = ShellConsoleService.Autocomplete(SessionKey, WorkingDirectory, _command);
        _command = result.Command;
        _autocompleteSuggestions = result.Suggestions;
        return InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ShellConsoleService.SessionChanged -= OnSessionChanged;
        _dotNetReference?.Dispose();
    }
}
