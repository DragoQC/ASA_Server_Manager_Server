@implements IDisposable
@inject asa_server_node_api.Services.ServerMonitorService ServerMonitor

<section class="space-y-8">
    <div class="flex flex-wrap items-center gap-4">
        <p class="text-xs font-semibold uppercase tracking-[0.45em] text-app-300">@Eyebrow</p>
        <StatusTag Text="@_snapshot.StatusLabel" />
    </div>

    <div>
        <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">@Title</h1>
        <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300 md:text-lg">
            @Description
        </p>
    </div>

    @if (_snapshot.CanManage)
    {
        @ChildContent(_snapshot)
    }
    else
    {
        <div class="grid gap-4 md:grid-cols-3">
            <MetricTile Label="Current state" Value="@_snapshot.StatusLabel" />
            <MetricTile Label="Substate" Value="@_snapshot.SubState" />
            <MetricTile Label="Last check" Value="@_snapshot.CheckedAtUtc.ToLocalTime().ToString("HH:mm:ss")" />
        </div>
    }
</section>

@code {
    private asa_server_node_api.Models.AsaServerStatusSnapshot _snapshot = asa_server_node_api.Models.AsaServerStatusSnapshot.Default("asa");

    [Parameter, EditorRequired]
    public RenderFragment<asa_server_node_api.Models.AsaServerStatusSnapshot> ChildContent { get; set; } = default!;

    [Parameter]
    public string Eyebrow { get; set; } = "Management";

    [Parameter]
    public string Title { get; set; } = "Management";

    [Parameter]
    public string Description { get; set; } = "You must connect to a server to manage it first.";

    protected override void OnInitialized()
    {
        _snapshot = ServerMonitor.GetSnapshot();
        ServerMonitor.StatusChanged += OnStatusChanged;
    }

    private void OnStatusChanged() =>
        _ = InvokeAsync(() =>
        {
            _snapshot = ServerMonitor.GetSnapshot();
            StateHasChanged();
        });

    public void Dispose() => ServerMonitor.StatusChanged -= OnStatusChanged;

    private static string MapStatus(asa_server_node_api.Models.AsaServerStatusSnapshot snapshot) =>
        snapshot.StatusLabel switch
        {
            "Running" => "OK",
            "Starting" or "Stopping" => "WARN",
            "Not installed" or "Failed" or "Unavailable" => "FAILED",
            _ => "UNKNOWN"
        };
}
