<DashboardValueCard Title="Players"
                    Subtitle="Online now"
                    Value="@(IsLoading ? "Loading..." : $"{Current}/{Max}")"
                    Description="Current online players out of the configured max player count." />

@code {
    [Parameter]
    public int Current { get; set; }

    [Parameter]
    public int Max { get; set; } = 30;

    [Parameter]
    public bool IsLoading { get; set; }
}
